			"com.craftable_nametag.CraftableNametagMod"
		],
		"client": [
			"com.craftable_nametag.client.CraftableNametagClient"
		]
	},
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=21"
	}
